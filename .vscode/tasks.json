{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Timesheet: dev server",
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": {
        "owner": "serve",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Accepting connections at"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
